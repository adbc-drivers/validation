sort-keys = [["res", "ascending"]]

[setup]
drop = "test_dictionary_encoded"

[tags]
sql-type-name = "VARCHAR"

// part: setup_query

CREATE TABLE test_dictionary_encoded (
    res VARCHAR(1000)
);

// part: bind_query

INSERT INTO test_dictionary_encoded VALUES ($1)

// part: bind_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "i",
            "flags": ["nullable"],
            "dictionary": {
                "format": "u"
            }
        }
    ]
}

// part: bind

{"res": "apple"}
{"res": "banana"}
{"res": "apple"}
{"res": null}

// part: query

SELECT res FROM test_dictionary_encoded ORDER BY res

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "u",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": null}
{"res": "apple"}
{"res": "apple"}
{"res": "banana"}
