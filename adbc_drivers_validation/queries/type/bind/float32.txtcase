sort-keys = [["res", "ascending"]]

[setup]
drop = "test_float32"

[tags]
sql-type-name = "REAL"

// part: setup_query

CREATE TABLE test_float32 (
    res REAL
);

// part: bind_query

INSERT INTO test_float32 VALUES ($1)

// part: bind_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "f",
            "flags": ["nullable"]
        }
    ]
}

// part: bind

{"res": 3.14159}
{"res": -2.5}
{"res": 0.0}
{"res": 3.4028235e+38}
{"res": -3.4028235e+38}
{"res": null}

// part: query

SELECT res FROM test_float32 ORDER BY res

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "f",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": null}
{"res": -3.4028235e+38}
{"res": -2.5}
{"res": 0.0}
{"res": 3.14159}
{"res": 3.4028235e+38}
