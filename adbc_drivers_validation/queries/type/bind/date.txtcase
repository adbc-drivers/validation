sort-keys = [["res", "ascending"]]

[setup]
drop = "test_date"

[tags]
sql-type-name = "DATE"

// part: setup_query

CREATE TABLE test_date (
    res DATE
);

// part: bind_query

INSERT INTO test_date VALUES ($1)

// part: bind_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "tdD",
            "flags": ["nullable"]
        }
    ]
}

// part: bind

{"res": 19492}
{"res": -719162}
{"res": -165}
{"res": 2932896}
{"res": null}

// part: query

SELECT res FROM test_date ORDER BY res

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "tdD",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": null}
{"res": -719162}
{"res": -165}
{"res": 19492}
{"res": 2932896}
