sort-keys = [["res", "ascending"]]

[setup]
drop = "test_binary"

[tags]
sql-type-name = "VARBINARY"

// part: setup_query

CREATE TABLE test_binary (
    res VARBINARY(1000)
);

// part: bind_query

INSERT INTO test_binary VALUES ($1)

// part: bind_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "z",
            "flags": ["nullable"]
        }
    ]
}

// part: bind

{"res": "44GT44KT44Gr44Gh44Gv44CB5LiW55WM77yB"}
{"res": "AA=="}
{"res": "AQAC"}
{"res": "3q2+7w=="}
{"res": ""}
{"res": null}

// part: query

SELECT res FROM test_binary ORDER BY res

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "z",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": null}
{"res": ""}
{"res": "3q2+7w=="}
{"res": "AA=="}
{"res": "AQAC"}
{"res": "44GT44KT44Gr44Gh44Gv44CB5LiW55WM77yB"}
