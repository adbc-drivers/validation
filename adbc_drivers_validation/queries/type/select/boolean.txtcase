[setup]
drop = "test_boolean"

[tags]
sql-type-name = "BOOLEAN"

// part: setup_query

CREATE TABLE test_boolean (
    idx INTEGER,
    res BOOLEAN
);

INSERT INTO test_boolean (idx, res) VALUES (1, TRUE);
INSERT INTO test_boolean (idx, res) VALUES (2, FALSE);
INSERT INTO test_boolean (idx, res) VALUES (3, NULL);

// part: query

SELECT res FROM test_boolean ORDER BY idx

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "b",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": true}
{"res": false}
{"res": null}
